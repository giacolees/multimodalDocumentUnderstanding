# Gemma-4-E2B-IT preset  (vllm serve google/gemma-4-E2B-it --tool-call-parser gemma4 ...)
VLLM_MODEL=google/gemma-4-E2B-it
VLLM_MAX_LEN=4096
VLLM_TP_SIZE=1
VLLM_EXTRA_ARGS=--enable-auto-tool-choice --tool-call-parser gemma4 --chat-template /templates/tool_chat_template_gemma4.jinja

LLAMA_MODEL_FILE=model.gguf
GPU_LAYERS=99

