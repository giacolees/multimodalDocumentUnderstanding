# Gemma-4-E2B-IT preset  (vllm serve google/gemma-4-E2B-it ...)
VLLM_MODEL=google/gemma-4-E2B-it
VLLM_MAX_LEN=4096
VLLM_TP_SIZE=1
VLLM_EXTRA_ARGS= --chat-template /templates/chat_template_gemma4.jinja --limit-mm-per-prompt.audio 0 --default-chat-template-kwargs '{"enable_thinking": false}'

LLAMA_MODEL_FILE=model.gguf
GPU_LAYERS=99

