# MiniCPM-V-4.6 preset  (vllm serve openbmb/MiniCPM-V-4.6 --trust-remote-code --tool-call-parser qwen3_coder)
VLLM_MODEL=openbmb/MiniCPM-V-4.6
VLLM_MAX_LEN=8192
VLLM_TP_SIZE=1
VLLM_EXTRA_ARGS=--trust-remote-code --max-num-batched-tokens 8192   --limit-mm-per-prompt '{"image": 5}'

LLAMA_MODEL_FILE=model.gguf
GPU_LAYERS=99